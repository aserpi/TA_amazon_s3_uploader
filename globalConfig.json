{
    "meta": {
        "displayName": "Amazon S3 Uploader for Splunk",
        "hideUCCVersion": true,
        "name": "TA_amazon_s3_uploader",
        "restRoot": "TA_amazon_s3_uploader",
        "schemaVersion": "0.0.10",
        "version": "2.0.1"
    },
    "alerts": [
        {
            "description": "Upload search results to an Amazon S3 bucket",
            "entity": [
                {
                    "field": "bucket_name",
                    "label": "Bucket name",
                    "required": true,
                    "type": "text"
                },
                {
                    "field": "object_key",
                    "help": "Only .csv, .csv.gz and .json files are supported.\nCan encode a timestamp.",
                    "label": "Object key",
                    "required": true,
                    "type": "text"
                },
                {
                    "defaultValue": "Boto3",
                    "field": "account",
                    "label": "Account",
                    "labelField": "title",
                    "required": true,
                    "search": "| rest /servicesNS/nobody/TA_amazon_s3_uploader/TA_amazon_s3_uploader_account | stats count by title | fields title | append [ | makeresults | eval title=&quot;Boto3&quot; ]",
                    "type": "singleSelectSplunkSearch",
                    "valueField": "title"
                },
                {
                    "field": "role",
                    "label": "Role",
                    "labelField": "title",
                    "search": "| rest /servicesNS/nobody/TA_amazon_s3_uploader/TA_amazon_s3_uploader_role | stats count by title | fields title",
                    "type": "singleSelectSplunkSearch",
                    "valueField": "title"
                },
                {
                    "field": "aws_region",
                    "help": "Only if you want to use regional endpoints.",
                    "label": "Region",
                    "type": "text"
                },
                {
                    "defaultValue": false,
                    "field": "utc",
                    "label": "Use UTC",
                    "required": false,
                    "type": "checkbox"
                },
                {
                    "defaultValue": true,
                    "field": "upload_empty",
                    "label": "Allow empty results",
                    "required": false,
                    "type": "checkbox"
                }
            ],
            "label": "Upload to Amazon S3",
            "name": "amazon_s3_upload"
        }
    ],
    "pages": {
        "configuration": {
            "description": "Set up your add-on",
            "tabs": [
                {
                    "entity": [
                        {
                            "field": "name",
                            "help": "Enter a unique name for this account.",
                            "label": "Account name",
                            "required": true,
                            "type": "text",
                            "validators": [
                                {
                                    "errorMsg": "Characters of Name should start with alphanumeric and contain alphanumeric, space, dash, underscore or comma only.",
                                    "pattern": "^[0-9|a-z|A-Z][\\w\\- ,]*$",
                                    "type": "regex"
                                },
                                {
                                    "errorMsg": "Maximum length allowed for account name is 50",
                                    "maxLength": 50,
                                    "minLength": 1,
                                    "type": "string"
                                },
                                {
                                    "errorMsg": "Cannot use this name",
                                    "pattern": "^(?!Boto3$).*$",
                                    "type": "regex"
                                }
                            ]
                        },
                        {
                            "field": "aws_key_id",
                            "label": "AWS access key ID",
                            "required": true,
                            "type": "text",
                            "validators": [
                                {
                                    "errorMsg": "AWS access key ID must contain between 16 and 128 word characters.",
                                    "pattern": "^[\\w]{16,128}$",
                                    "type": "regex"
                                }
                            ]
                        },
                        {
                            "encrypted": true,
                            "field": "aws_secret",
                            "label": "AWS secret access key",
                            "required": true,
                            "type": "text"
                        },
                        {
                            "encrypted": true,
                            "field": "aws_session_token",
                            "label": "AWS session token",
                            "required": false,
                            "type": "text",
                            "validators": [
                                {
                                    "errorMsg": "AWS session token must be contain only uppercase letters, numbers, plus signs or slashes.",
                                    "pattern": "^[a-zA-Z0-9+/]+$",
                                    "type": "regex"
                                }
                            ]
                        }
                    ],
                    "name": "account",
                    "table": {
                        "actions": [
                            "edit",
                            "delete",
                            "clone"
                        ],
                        "header": [
                            {
                                "field": "name",
                                "label": "Name"
                            },
                            {
                                "field": "aws_key_id",
                                "label": "AWS access key ID"
                            }
                        ]
                    },
                    "title": "Account"
                },
                {
                    "entity": [
                        {
                            "field": "name",
                            "help": "Enter a unique name for this role.",
                            "label": "Name",
                            "required": true,
                            "type": "text",
                            "validators": [
                                {
                                    "errorMsg": "Characters of Name should start with alphanumeric and contain alphanumeric, space, dash, underscore or comma only.",
                                    "pattern": "^[0-9|a-z|A-Z][\\w\\- ,]*$",
                                    "type": "regex"
                                },
                                {
                                    "errorMsg": "Maximum length allowed for role name is 50",
                                    "maxLength": 50,
                                    "minLength": 1,
                                    "type": "string"
                                }
                            ]
                        },
                        {
                            "field": "aws_arn",
                            "label": "Role ARN",
                            "required": true,
                            "type": "text",
                            "validators": [
                                {
                                    "errorMsg": "Invalid role ARN.",
                                    "pattern": "^arn:aws:iam::[\\d]{12}:role/[A-Za-z0-9_+=,.@-]+$",
                                    "type": "regex"
                                }
                            ]
                        }
                    ],
                    "name": "role",
                    "table": {
                        "actions": [
                            "edit",
                            "delete",
                            "clone"
                        ],
                        "header": [
                            {
                                "field": "name",
                                "label": " Name"
                            },
                            {
                                "field": "aws_arn",
                                "label": "Role ARN"
                            }
                        ]
                    },
                    "title": "IAM Role"
                },
                {
                    "dns_resolution": {
                        "field": "proxy_rdns",
                        "label": "Disable TLS verification",
                        "type": "checkbox"
                    },
                    "host": {
                        "field": "proxy_url",
                        "label": "Host",
                        "required": true,
                        "type": "text",
                        "validators": [
                            {
                                "errorMsg": "Max host length is 4096",
                                "maxLength": 4096,
                                "minLength": 1,
                                "type": "string"
                            },
                            {
                                "errorMsg": "Proxy Host should be an FQDN, IPv4 or IPv6 address",
                                "pattern": "^[A-Za-z0-9.:]+$",
                                "type": "regex"
                            }
                        ]
                    },
                    "password": true,
                    "proxy_type": {
                        "defaultValue": "http",
                        "field": "proxy_type",
                        "label": "Proxy Type",
                        "options": {
                            "autoCompleteFields": [
                                {
                                    "label": "http",
                                    "value": "http"
                                },
                                {
                                    "label": "https",
                                    "value": "https"
                                }
                            ],
                            "disableSearch": true
                        },
                        "required": false,
                        "type": "singleSelect"
                    },
                    "type": "proxyTab",
                    "username": true
                },
                {
                    "type": "loggingTab"
                }
            ],
            "title": "Configuration"
        }
    }
}
